# Firecrawl — AXON-01 Edge Deployment
# Copy to .env and adjust as needed.

# Ollama runs natively on AXON-01 host (not containerized).
# host.docker.internal resolves via extra_hosts: host-gateway on firecrawl-api.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Redis (dedicated instance, not shared)
REDIS_URL=redis://firecrawl-redis:6379

# Worker config (conservative for shared edge server)
NUM_WORKERS_PER_QUEUE=2
CRAWL_CONCURRENT_REQUESTS=4
MAX_CONCURRENT_JOBS=3
BROWSER_POOL_SIZE=2

# No auth for local self-hosted
USE_DB_AUTHENTICATION=false

# Block media downloads to save bandwidth/disk
BLOCK_MEDIA=true

# Logging
LOGGING_LEVEL=INFO
